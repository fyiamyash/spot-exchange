// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                    String                @id
  username                              String
  password                              String
  makerFills                            Fills[]               @relation("makerFills")                
  takerFills                            Fills[]               @relation("takerFills")   
  orderHistory                          Orders[]              @relation("orderHistory")      
}

model Fills{
  id                                    String                 @id

  makerId                               String
  maker_id                              User                   @relation("makerFills",fields: [makerId], references: [id]) 

  takerId                               String
  taker_Id                              User                    @relation("takerFills",fields: [takerId], references: [id])

  market                                String

  price                                 Int

  quantity                              Int

  createdAt                             String
}



model Orders{
  id                                    String                                @id

  userId                                String
  user_Id                               User                                   @relation("orderHistory",fields: [userId], references: [id])

  price                                 Int

  side                                  String

  quantity                              Int

  filledQuantity                        Int

  status                                String

  createdAt                             String

  market                                String

}



